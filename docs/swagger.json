{
    "swagger": "2.0",
    "info": {
        "description": "Blog loyihasi API",
        "title": "Blog API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/articles": {
            "get": {
                "description": "Ma'lumotlar bazasidan barcha maqolalar ro'yxatini qaytaradi",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "articles"
                ],
                "summary": "Barcha maqolalarni olish",
                "responses": {
                    "200": {
                        "description": "Maqolalar ro'yxati muvaffaqiyatli qaytarildi",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Article"
                            }
                        }
                    },
                    "500": {
                        "description": "Ichki server xatosi",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/articles/create": {
            "post": {
                "description": "Title va content bilan yangi article yaratadi",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "articles"
                ],
                "summary": "Yangi article yaratish",
                "parameters": [
                    {
                        "description": "Article ma'lumotlari",
                        "name": "article",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.CreateArticleRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "muvafaqiyatli qo'shildi",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Noto'g'ri so'rov",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Server xatosi",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/articles/delete": {
            "delete": {
                "tags": [
                    "articles"
                ],
                "summary": "Article o'chirish",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Article ID",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "o'chirildi",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "id noto'g'ri",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "server xatosi",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/articles/get": {
            "get": {
                "description": "Malumotlar bazasidan bitta maqolani qaytaradi",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "articles"
                ],
                "summary": "bitta Article o'qish",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Article ID",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "maqola  muvaffaqiyatli qaytarildi",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Article"
                            }
                        }
                    },
                    "500": {
                        "description": "Ichki server xatosi",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/articles/update": {
            "put": {
                "description": "Article title, content va active holatini yangilaydi",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "articles"
                ],
                "summary": "Article yangilash",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Article ID",
                        "name": "id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "description": "Article ma'lumotlari",
                        "name": "article",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.UpdateArticleRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "yangilandi",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "id noto'g'ri",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "server xatosi",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.CreateArticleRequest": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "dto.UpdateArticleRequest": {
            "type": "object",
            "properties": {
                "active": {
                    "type": "boolean"
                },
                "content": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "models.Article": {
            "type": "object",
            "properties": {
                "active": {
                    "type": "boolean"
                },
                "content": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "integer",
                    "format": "int64"
                },
                "title": {
                    "type": "string"
                },
                "userID": {
                    "type": "integer",
                    "format": "int64"
                },
                "viewCount": {
                    "type": "integer",
                    "format": "int64"
                }
            }
        }
    }
}